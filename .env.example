# ============================================================
# NewsHive — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
DATABASE_URL=postgresql://newshive_user:password@newshive-postgres:5432/newshive
REDIS_URL=redis://:password@newshive-redis:6379

# ------------------------------------------------------------
# AI APIs
# ------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
PERPLEXITY_API_KEY=

# ------------------------------------------------------------
# Media — ElevenLabs & HeyGen
# ------------------------------------------------------------
ELEVENLABS_API_KEY=
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=

# ------------------------------------------------------------
# Publishing — Meta (Instagram + Facebook)
# ------------------------------------------------------------
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
FACEBOOK_PAGE_ID=

# ------------------------------------------------------------
# Publishing — LinkedIn
# ------------------------------------------------------------
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=

# ------------------------------------------------------------
# Publishing — X / Twitter
# ------------------------------------------------------------
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# ------------------------------------------------------------
# Publishing — YouTube
# ------------------------------------------------------------
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ------------------------------------------------------------
# News APIs
# ------------------------------------------------------------
NEWS_API_KEY=
DIFFBOT_TOKEN=

# ------------------------------------------------------------
# Reddit API (for PRAW ingestion)
# ------------------------------------------------------------
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=NewsHive/1.0

# ------------------------------------------------------------
# GitHub API (for trending / release monitoring)
# ------------------------------------------------------------
GITHUB_ACCESS_TOKEN=

# ------------------------------------------------------------
# Next.js Application
# ------------------------------------------------------------
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://newshive.geekybee.net
OPERATOR_EMAIL=
DASHBOARD_PASSWORD_HASH=
PYTHON_SERVICE_URL=http://newshive-python:8000

# ------------------------------------------------------------
# Security — Honeypot
# HONEYPOT_ENCRYPTION_KEY must be a 64-character hex string (32 bytes)
# Generate with: openssl rand -hex 32
# ------------------------------------------------------------
HONEYPOT_ENCRYPTION_KEY=

# ------------------------------------------------------------
# Tor Hidden Service
# ------------------------------------------------------------
TOR_HIDDEN_SERVICE_DIR=/var/lib/tor/hidden_service
